# Copy to .env.production on your VPS before: docker compose up -d --build
#   cp env.production.example .env.production
#   nano .env.production

POLYGON_API_KEY=your_massive_key_here

# REQUIRED in production — protects your API quota if port 8780 is reachable.
# Generate:  openssl rand -hex 24
# Sent as x-scan-token header or Authorization: Bearer (?token= is rejected).
SCAN_API_TOKEN=change_me_to_a_long_random_string

# Hard API spend ceilings (calls refused past the cap; loop backs off like 429)
POLYGON_DAILY_CALL_CAP=200000
POLYGON_MINUTE_CALL_CAP=280

# Discord alerts (optional but recommended when away from PC)
DISCORD_WEBHOOK_URL=

# Scanner defaults (tuned for paid real-time plan)
SCANNER_REALTIME=1
SCANNER_LOOP_MS=1000
SCANNER_MIN_RATE_PCT_MIN=0.2
SCANNER_MIN_VOL_SURGE=1.4
SCANNER_MIN_EFFICIENCY=0.35
ALERT_MIN_MOMENTUM_SCORE=62

# Stocks mode (premarket 4:00-9:30 + after-hours 16:00-20:00 ET, shares only)
# Minimum stock setup score for a callout to persist (BUY needs speed+volume too)
STOCK_MIN_SCORE=66
STOCK_CALLOUTS=1
STOCK_MOMENTUM_MIN_PRICE=0.5
STOCK_MOMENTUM_MAX_PRICE=50
STOCK_MOMENTUM_MIN_DAY_VOLUME=500000
STOCK_MOMENTUM_MIN_GAIN_FROM_PREV_CLOSE_PCT=10
STOCK_FAST_MIN_RET_10S_PCT=0.40
STOCK_FAST_MIN_RET_30S_PCT=1.00
STOCK_FAST_MIN_RET_60S_PCT=1.50
STOCK_FAST_MIN_VELOCITY_PCT_PER_MIN=2.00

# Confirmed options universe and verified puts
SUPERVISOR_CORE_TICKERS=SPY,QQQ,NVDA,AAPL,META,TSLA,AMD,AMZN,MSFT,GOOGL,NFLX,AVGO,IWM,SPCX
SUPERVISOR_MAX_TICKERS=14
OPTIONS_PUTS_ENABLED=1
OPTIONS_PUT_CALLOUTS=1

# Paper portfolios
PAPER_CHALLENGE_MAX_POSITION_PCT=60
PAPER_CHALLENGE_MAX_TOTAL_EXPOSURE_PCT=60
PAPER_STOCK_DAY_STARTING_BALANCE_USD=10000

# TRADE-tier order gates (audit 2026-07-07): a BUY callout requires the exact
# contract to be fillable — spread cap in %, delta 0.35-0.65, breakeven within
# the expected remaining move. WATCH callouts are unaffected.
TRADE_MAX_SPREAD_PCT=5
