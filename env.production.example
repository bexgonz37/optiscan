# Copy to .env.production on your VPS before: docker compose up -d --build
#   cp env.production.example .env.production
#   nano .env.production

POLYGON_API_KEY=your_massive_key_here

# Strongly recommended — protects your API if port 8780 is reachable.
SCAN_API_TOKEN=change_me_to_a_long_random_string

# Discord alerts (optional but recommended when away from PC)
DISCORD_WEBHOOK_URL=

# Scanner defaults (tuned for paid real-time plan)
SCANNER_REALTIME=1
SCANNER_LOOP_MS=1000
SCANNER_MIN_RATE_PCT_MIN=0.2
SCANNER_MIN_VOL_SURGE=1.4
SCANNER_MIN_EFFICIENCY=0.35
ALERT_MIN_MOMENTUM_SCORE=62

# Stocks mode (premarket 4:00-9:30 + after-hours 16:00-20:00 ET, shares only)
# Minimum stock setup score for a callout to persist (BUY needs speed+volume too)
STOCK_MIN_SCORE=66

# TRADE-tier order gates (audit 2026-07-07): a BUY callout requires the exact
# contract to be fillable — spread cap in %, delta 0.35-0.65, breakeven within
# the expected remaining move. WATCH callouts are unaffected.
TRADE_MAX_SPREAD_PCT=5
