# OptiScan — copy this file to .env.local and fill in your key.
#   cp .env.local.example .env.local   (macOS/Linux)
#   copy .env.local.example .env.local (Windows)

# ── Data provider: Polygon / Massive (stocks + options, one key covers both) ──
# Get a key at https://polygon.io/ (Massive is the rebrand; same API + keys).
# Free tier = 15-min delayed + ~5 calls/min. Options snapshots need the Options
# product; real-time needs the Advanced plan.
POLYGON_API_KEY=

# ── Scan universe (optional) ─────────────────────────────────────────────────
# Replace the built-in liquid universe, or just append to it.
# SCAN_UNIVERSE=AAPL,MSFT,NVDA,SPY,QQQ,TSLA
# SCAN_UNIVERSE_EXTRA=SMCI,ARM

# ── Scan sizing / rate-limit controls ────────────────────────────────────────
# How many of the biggest movers to pull option chains for each scan.
# Each shortlisted symbol = ~2 provider calls (candles + chain). On the free
# 5-calls/min tier keep this small (e.g. 4); raise it after upgrading.
RADAR_SHORTLIST=12
# Parallel chain fetches (bounded to protect the rate limit).
SCAN_CONCURRENCY=4
# Cache window: repeat polls within this many ms are served from memory.
SCAN_CACHE_MS=45000
# Fold Polygon's whole-market top gainers/losers into the shortlist.
SCAN_INCLUDE_MOVERS=1
SCAN_MOVERS_PER_SIDE=10

# ── Momentum tuning (optional) ───────────────────────────────────────────────
# RADAR_MIN_PRICE=3
# RADAR_MIN_MOVE_PCT=1.0
# RADAR_MIN_REL_VOL=1.2
# RADAR_RSI_OVERBOUGHT=82

# ── Options contract selection (momentum tab) ────────────────────────────────
# OPTIONS_TARGET_DELTA=0.4
# OPTIONS_MIN_DTE=3
# OPTIONS_MAX_DTE=45
# OPTIONS_MAX_SPREAD_PCT=15
# OPTIONS_MIN_OPEN_INTEREST=100

# ── Unusual activity thresholds (unusual tab) ────────────────────────────────
# UNUSUAL_MIN_VOLUME=200        # contract day volume floor
# UNUSUAL_MIN_VOL_OI=1.0        # volume / open interest ratio floor
# UNUSUAL_MIN_OI=0              # open interest floor (0 = allow new strikes)
# UNUSUAL_MAX_SPREAD_PCT=30
# UNUSUAL_MIN_MID=0.05
# UNUSUAL_TOP_PER_UNDERLYING=6
