# OptiScan — copy this file to .env.local and fill in your key.
#   cp .env.local.example .env.local   (macOS/Linux)
#   copy .env.local.example .env.local (Windows)

# ── Data provider: Polygon / Massive (stocks + options, one key covers both) ──
# Get a key at https://polygon.io/ (Massive is the rebrand; same API + keys).
# Free tier = 15-min delayed + ~5 calls/min. Options snapshots need the Options
# product; real-time needs the Advanced plan.
POLYGON_API_KEY=

# Optional: require a token on /api/scan/* (quota protection if the URL leaks).
# Browser side: localStorage.setItem("optiscan:token", "<same value>") once.
# SCAN_API_TOKEN=

# Per-request timeout against Polygon (ms).
# POLYGON_TIMEOUT_MS=10000

# ── Scan universe (optional) ─────────────────────────────────────────────────
# Replace the built-in liquid universe, or just append to it.
# SCAN_UNIVERSE=AAPL,MSFT,NVDA,SPY,QQQ,TSLA
# SCAN_UNIVERSE_EXTRA=SMCI,ARM

# ── Scan sizing / rate-limit controls ────────────────────────────────────────
# How many of the biggest movers to pull option chains for each scan.
# Each shortlisted symbol = ~2 provider calls (candles + chain). On the free
# 5-calls/min tier keep this small (e.g. 4); raise it after upgrading.
RADAR_SHORTLIST=12
# Parallel chain fetches (bounded to protect the rate limit).
SCAN_CONCURRENCY=4
# Fallback cache window (ms). The UI sends its own freshness based on its poll
# interval (15-120s, chosen in the top bar), so this mostly matters for direct
# API hits. Effective refresh is bounded by how long a scan takes (candles +
# chain per shortlisted symbol ≈ 27+ calls); free tiers (~5 calls/min) should
# poll at 120s with a small shortlist.
SCAN_CACHE_MS=15000
# Max snapshot pages to follow per option chain (250 contracts/page). Wide
# chains (SPY, TSLA) need >1 page or contracts silently never get evaluated.
# OPTIONS_CHAIN_MAX_PAGES=4
# Fold Polygon's whole-market top gainers/losers into the shortlist.
SCAN_INCLUDE_MOVERS=1
SCAN_MOVERS_PER_SIDE=10

# ── Momentum tuning (optional) ───────────────────────────────────────────────
# RADAR_MIN_PRICE=3
# RADAR_MIN_MOVE_PCT=1.0
# RADAR_MIN_REL_VOL=1.2
# RADAR_RSI_OVERBOUGHT=82

# ── Options contract selection (momentum tab) ────────────────────────────────
# OPTIONS_TARGET_DELTA=0.4
# OPTIONS_MIN_DTE=3
# OPTIONS_MAX_DTE=45
# OPTIONS_MAX_SPREAD_PCT=15
# OPTIONS_MIN_OPEN_INTEREST=100

# ── Unusual activity thresholds (unusual tab) ────────────────────────────────
# UNUSUAL_MIN_VOLUME=200        # contract day volume floor
# UNUSUAL_MIN_VOL_OI=1.0        # volume / open interest ratio floor
# UNUSUAL_MIN_OI=0              # open interest floor (0 = allow new strikes)
# UNUSUAL_MAX_SPREAD_PCT=30
# UNUSUAL_MIN_MID=0.05
# UNUSUAL_TOP_PER_UNDERLYING=6

# ── Alert Lab (persisted alert tracking) ─────────────────────────────────────
# Master switch (1 = on). Alerts persist to data/optiscan.db (better-sqlite3).
# ALERT_LAB_ENABLED=1
# Capture thresholds: momentum score (GOOD+) and unusual score (STRONG).
# ALERT_MIN_MOMENTUM_SCORE=65
# ALERT_MIN_UNUSUAL_SCORE=80
# Checkpoint sweep cadence (ms) for the in-process tracker.
# ALERT_TRACK_INTERVAL_MS=60000
# False-positive rule: min favorable % move an alert must print by EOD.
# ALERT_FP_MIN_FAVORABLE_PCT=1.5
# Override the DB directory (default: ./data).
# ALERT_DB_DIR=

# ── Discord alerts (OFF by default; built for later public/education use) ───
# Webhook URL is server-side only and never exposed to the browser.
# DISCORD_WEBHOOK_URL=
# Enabling/confirm-mode is controlled in /settings (stored in the DB), not here.
