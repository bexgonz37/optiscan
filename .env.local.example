# OptiScan — copy this file to .env.local and fill in your key.
#   cp .env.local.example .env.local   (macOS/Linux)
#   copy .env.local.example .env.local (Windows)

# ── Data provider: Polygon / Massive (stocks + options, one key covers both) ──
# Get a key at https://polygon.io/ (Massive is the rebrand; same API + keys).
# Free tier = 15-min delayed + ~5 calls/min. Options snapshots need the Options
# product; real-time needs the Advanced plan.
POLYGON_API_KEY=

# Require a token on /api/scan/* (quota protection if the URL leaks).
# Generate one:  openssl rand -hex 24
# Browser side: localStorage.setItem("optiscan:token", "<same value>") once.
# Sent as the x-scan-token header or Authorization: Bearer — query-string
# ?token= is NOT accepted (it leaks into logs and referrers).
# SCAN_API_TOKEN=

# Per-request timeout against Polygon (ms).
# POLYGON_TIMEOUT_MS=10000

# ── Hard API spend caps (audit P0-2) ─────────────────────────────────────────
# Central call meter in polygon-provider counts EVERY provider request,
# bucketed by ET trading day + wall-clock minute. At a cap the request is
# refused with a typed quota_exceeded error (loop backs off like a 429).
# Set a cap to 0 to disable it. Stats surface via /api/health.
# POLYGON_DAILY_CALL_CAP=200000
# POLYGON_MINUTE_CALL_CAP=280

# ── Scan universe (optional) ─────────────────────────────────────────────────
# Replace the built-in liquid universe, or just append to it.
# SCAN_UNIVERSE=AAPL,MSFT,NVDA,SPY,QQQ,TSLA
# SCAN_UNIVERSE_EXTRA=SMCI,ARM

# ── Scan sizing / rate-limit controls ────────────────────────────────────────
# How many of the biggest movers to pull option chains for each scan.
# Each shortlisted symbol = ~2 provider calls (candles + chain). On the free
# 5-calls/min tier keep this small (e.g. 4); raise it after upgrading.
RADAR_SHORTLIST=12
# Parallel chain fetches (bounded to protect the rate limit).
SCAN_CONCURRENCY=4
# Fallback cache window (ms). The UI sends its own freshness based on its poll
# interval (15-120s, chosen in the top bar), so this mostly matters for direct
# API hits. Effective refresh is bounded by how long a scan takes (candles +
# chain per shortlisted symbol ≈ 27+ calls); free tiers (~5 calls/min) should
# poll at 120s with a small shortlist.
SCAN_CACHE_MS=15000
# Max snapshot pages to follow per option chain (250 contracts/page). Wide
# chains (SPY, TSLA) need >1 page or contracts silently never get evaluated.
# OPTIONS_CHAIN_MAX_PAGES=4
# Fold Polygon's whole-market top gainers/losers into the shortlist.
SCAN_INCLUDE_MOVERS=1
SCAN_MOVERS_PER_SIDE=10

# ── Momentum tuning (optional) ───────────────────────────────────────────────
# RADAR_MIN_PRICE=3
# RADAR_MIN_MOVE_PCT=1.0
# RADAR_MIN_REL_VOL=1.2
# RADAR_RSI_OVERBOUGHT=82

# ── Options contract selection (momentum tab) ────────────────────────────────
# OPTIONS_TARGET_DELTA=0.4
# OPTIONS_MIN_DTE=3
# OPTIONS_MAX_DTE=45
# OPTIONS_MAX_SPREAD_PCT=15
# OPTIONS_MIN_OPEN_INTEREST=100

# ── Unusual activity thresholds (unusual tab) ────────────────────────────────
# UNUSUAL_MIN_VOLUME=200        # contract day volume floor
# UNUSUAL_MIN_VOL_OI=1.0        # volume / open interest ratio floor
# UNUSUAL_MIN_OI=0              # open interest floor (0 = allow new strikes)
# UNUSUAL_MAX_SPREAD_PCT=30
# UNUSUAL_MIN_MID=0.05
# UNUSUAL_TOP_PER_UNDERLYING=6

# ── Alert Lab (persisted alert tracking) ─────────────────────────────────────
# Master switch (1 = on). Alerts persist to data/optiscan.db (better-sqlite3).
# ALERT_LAB_ENABLED=1
# Capture thresholds: momentum score (GOOD+) and unusual score (STRONG).
# ALERT_MIN_MOMENTUM_SCORE=65
# ALERT_MIN_UNUSUAL_SCORE=80
# Checkpoint sweep cadence (ms) for the in-process tracker.
# ALERT_TRACK_INTERVAL_MS=60000
# False-positive rule: min favorable % move an alert must print by EOD.
# ALERT_FP_MIN_FAVORABLE_PCT=1.5
# Override the DB directory (default: ./data).
# ALERT_DB_DIR=

# ── Discord alerts ───────────────────────────────────────────────────────────
# Webhook URLs are server-side only and never exposed to the browser.
# DISCORD_WEBHOOK_URL=                # legacy fallback for options only
# DISCORD_WEBHOOK_OPTIONS=            # #options-callouts
# DISCORD_WEBHOOK_STOCKS=             # required for #stock-callouts; never falls back to options
# DISCORD_WEBHOOK_RECAP=             # #track-record scoreboard
# DISCORD_ROLE_0DTE=                  # optional @role on BUY pings
# DISCORD_ROLE_STOCKS=
# PUBLIC_APP_URL=https://yoursite.com # scoreboard footer links here /alerts
# STOCK_CALLOUTS=1                    # re-enable shares engine (premarket/AH/RTH routing)

# ── 0DTE realtime scanner loop ───────────────────────────────────────────────
# The every-second underlying loop (needs a paid real-time Polygon plan; a
# free/delayed key auto-backs-off on 429s but alerts will be delayed data).
# SCANNER_REALTIME=1              # set 0 to disable the loop entirely
# SCANNER_LOOP_MS=1000            # loop heartbeat (ms)
# SCANNER_0DTE_UNIVERSE=SPY,QQQ,IWM,TSLA,NVDA   # override the built-in list
# SCANNER_0DTE_UNIVERSE_EXTRA=SPCX                # append without replacing core
# Broad options discovery: top movers are promoted into the 1s loop; chains
# remain trigger-gated and are never fetched for the entire discovery pool.
# SCANNER_DISCOVERY_MS=30000
# SCANNER_DISCOVERY_TOP_N=20
# SCANNER_PROMOTION_MS=300000
# SCANNER_DISCOVERY_MIN_VOLUME=100000
# SCANNER_DISCOVERY_UNIVERSE=                      # optional override; default ~243
# SCANNER_MIN_RATE_PCT_MIN=0.2    # trigger: min |%/min| 15s velocity (audit: <0.15 fires on noise)
# SCANNER_MIN_VOL_SURGE=1.4       # trigger: min volume-surge ratio (30s window)
# SCANNER_TRIGGER_COOLDOWN_MS=600000  # 10 min per-symbol re-trigger cooldown
# TRADE_MAX_SPREAD_PCT=5          # BUY requires contract spread at/under this
# SCANNER_ACTIVE_REFRESH_MS=7000  # live option re-quotes for active alerts

# ── Paper trading (v1.2) ────────────────────────────────────────────────────────
# Simulated options trades: limit fills (pay ask / exit bid), hard + smart
# exits, risk engine. No broker, ever. Dashboard: /paper
# PAPER_TRADING_ENABLED=1          # 0 disables the sweep engine
# PAPER_SWEEP_MS=30000
# PAPER_SWEEP_MAX_FETCHES=5        # quote fetches per sweep (budget bound)
# PAPER_MAX_RISK_PER_TRADE=200     # $ at risk (premium x stop distance)
# PAPER_MAX_DAILY_LOSS=500
# PAPER_MAX_WEEKLY_LOSS=1500
# PAPER_MAX_OPEN_TRADES=3
# PAPER_MAX_TICKER_EXPOSURE=400
# PAPER_ALLOW_AVERAGING_DOWN=0
# PAPER_ALLOW_ZERO_DTE=0           # 0DTE excluded from paper mode by default
# PAPER_STOP_LOSS_PCT=30
# PAPER_TAKE_PROFIT_PCT=50
# PAPER_SMART_EXITS=1              # thesis-invalidation exits
# PAPER_ENTRY_WINDOW_MS=600000     # unfilled entries cancel after 10 min
# ── Autonomous paper trading ─────────────────────────────────────────────
# PAPER_AUTO_ENTRY=1               # every fresh TRADE callout auto-becomes a
#                                  # paper trade (risk engine still gatekeeps)
# PAPER_ALLOW_ZERO_DTE=1           # required with auto-entry: live TRADE
#                                  # callouts are 0DTE contracts
# PAPER_AUTO_ENTRY_MAX_AGE_MS=600000  # ignore callouts older than 10 min
# PAPER_MIN_POSITION_DOLLARS=1000     # experiment: size each paper entry to about this exposure
# PAPER_TARGET_PROFIT_DOLLARS=200     # display/risk-context goal only; profit is not guaranteed
# PAPER_EXPERIMENTAL_OVERSIZE=1       # paper-only: lets dollar caps widen for the target size

# ── Swing scanner (research preview) ────────────────────────────────────────
# 1-4 week candidates, manual runs, cached 15 min. docs/SWING-SCANNER.md
# SWING_CACHE_MS=900000
# SWING_CHAIN_CANDIDATES=12        # chain fetches per run (budget bound)
# SWING_MAX_SPREAD_PCT=8
# SWING_MIN_OI=250

# ── Verdict display hysteresis (v1.1) ────────────────────────────────────
# NEXT_PUBLIC_VERDICT_HOLD_MS=25000  # downgrades commit only after persisting
