# ==========================================================================
# OptiScan — Railway deployment environment (EXAMPLE / placeholders only)
# ==========================================================================
# Copy the values you need into the Railway service "Variables" tab.
# NEVER commit real secrets. This file contains placeholders only.
#
# Booleans use the repo convention: the string "1" (or "0" to disable) — see each
# variable. Anything not listed here uses a production-safe in-code default.
#
# Staged go-live: start with STAGE A (safe), then B (supervisor observe), then C
# (live Discord). See docs/RAILWAY_DEPLOYMENT.md.

# --------------------------------------------------------------------------
# Runtime platform (Railway)
# --------------------------------------------------------------------------
NODE_ENV=production
# PORT is INJECTED by Railway — do NOT set it. The container reads process.env.PORT.
# HOSTNAME=0.0.0.0 is set by the image; leave as-is.

# Persistent SQLite directory — MUST point inside the mounted Railway volume.
# Mount the volume at /app/data (see docs) and keep this value.
ALERT_DB_DIR=/app/data

# Public base URL for dashboard links in Discord embeds (optional but recommended).
PUBLIC_APP_URL=https://your-app.up.railway.app

# --------------------------------------------------------------------------
# Market data provider (Polygon / Massive) — SECRET, required for live data
# --------------------------------------------------------------------------
# One of these is required for live signals. POLYGON_API_KEY wins if both are set.
POLYGON_API_KEY=your_polygon_or_massive_key_here
# MASSIVE_API_KEY=your_massive_key_here
# Optional overrides (defaults shown):
# POLYGON_API_URL=https://api.polygon.io
# POLYGON_DAILY_CALL_CAP=50000
# POLYGON_MINUTE_CALL_CAP=100
# POLYGON_TIMEOUT_MS=12000

# --------------------------------------------------------------------------
# API access token — SECRET, optional but STRONGLY recommended for production
# --------------------------------------------------------------------------
# Unset = protected routes are OPEN. Set a random token to gate /api/* (send it as
# the x-scan-token header). Generate: openssl rand -hex 24
SCAN_API_TOKEN=generate_a_random_hex_token

# --------------------------------------------------------------------------
# Discord webhooks — SECRET (optional; callouts degrade gracefully if unset)
# --------------------------------------------------------------------------
# Option CALLS + PUT RESEARCH route to the options webhook; momentum stock to stocks.
DISCORD_WEBHOOK_OPTIONS=https://discord.com/api/webhooks/xxx/yyy
DISCORD_WEBHOOK_STOCKS=https://discord.com/api/webhooks/xxx/yyy
DISCORD_WEBHOOK_RECAP=https://discord.com/api/webhooks/xxx/yyy
# Fallback used when a specific webhook is unset:
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# Optional role-mention IDs (numeric Discord role IDs, not secrets):
# DISCORD_ROLE_0DTE=123456789012345678
# DISCORD_ROLE_STOCKS=123456789012345678

# --------------------------------------------------------------------------
# Live runtime wiring — the flags that stage the go-live (all default SAFE)
# --------------------------------------------------------------------------
# Scanner + paper engine are ON unless explicitly disabled:
# SCANNER_REALTIME=0        # "0" disables the scanner loop (default: enabled)
# PAPER_TRADING_ENABLED=0   # "0" disables the paper engine (default: enabled)
# SCHEDULER_DISABLED=1      # "1" disables the background scheduler (default: enabled)

# Supervisor multi-horizon callout cycle:
SUPERVISOR_RUNTIME=1        # "1" = run the automatic supervisor callout cycle
# Pinned CORE tickers: always scanned first (before dynamic movers), deduped,
# invalid symbols ignored. Comma/space separated. Default shown.
OWNER_CORE_TICKERS=NVDA,META,SPY,QQQ,AAPL,AMZN,MSFT,TSLA,AMD,GOOGL
SUPERVISOR_CORE_TICKERS=NVDA,META,SPY,QQQ,AAPL,AMZN,MSFT,TSLA,AMD,GOOGL
SUPERVISOR_MAX_TICKERS=12   # total cap per cycle (1-50); ten core names plus top movers
SUPERVISOR_CHAIN_CONCURRENCY=3 # bounded parallel option-chain ticker evaluations

# Which system owns OPTIONS Discord callouts. "legacy" (default) or "supervisor".
# "supervisor" stands the legacy options sender down (prevents double-send).
CALLOUT_CANONICAL_PATH=supervisor

# Master switch permitting supervisor Discord delivery:
AGENT_CALLOUT_DISCORD=1     # "1" = allow supervisor callouts to actually send

# Momentum stock callouts to Discord:
STOCK_CALLOUTS=1

# Paper trading / auto-entry safety:
PAPER_TRADING_ENABLED=1
PAPER_AUTO_ENTRY=1
PAPER_ALLOW_ZERO_DTE=1
PAPER_KILL_SWITCH=0
EARLY_ALERTS_ENABLED=0

# Scheduler cadences (ms) — defaults shown; clamped in code:
# SCHED_MAINTENANCE_MS=300000     # outcome sync + stats refresh (60s–1h)
# SCHED_LEARNING_MS=3600000       # bounded learning cycle (10m–24h)
# SCHED_SUPERVISOR_MS=60000       # supervisor cycle (15s–30m)
# SCHED_IMPROVEMENT_MS=21600000   # improvement audit (1h–7d)

# --------------------------------------------------------------------------
# Improvement agent — proposal-only; keep automation OFF
# --------------------------------------------------------------------------
IMPROVEMENT_AUDIT=0          # "1" = record proposal-only audits (after validation)
# IMPROVEMENT_AUTOMATION and IMPROVEMENT_AUTO_MERGE must stay UNSET/0 in production.
# IMPROVEMENT_AUTOMATION=0
# IMPROVEMENT_AUTO_MERGE=0

# --------------------------------------------------------------------------
# Discord smoke test — disabled by default; enable only for a manual check
# --------------------------------------------------------------------------
# DISCORD_SMOKE_TEST=1       # "1" permits GET /api/dev/discord-smoke?send=1 to send

# --------------------------------------------------------------------------
# SAFETY — must NOT be set in production
# --------------------------------------------------------------------------
# BEARISH_ACTIONABLE stays OFF (research-only puts). Do NOT set it to 1.
# BEARISH_ACTIONABLE=0

# --------------------------------------------------------------------------
# Model / learning thresholds — optional (production-safe defaults in code)
# --------------------------------------------------------------------------
# Validated model gates (defaults): 200 / 40 / 40 / 50 / 0.95 / 0.15
# MODEL_MIN_GRADED=200
# MODEL_MIN_WINS=40
# MODEL_MIN_LOSSES=40
# MODEL_MIN_HOLDOUT=50
# MODEL_MIN_COVERAGE=0.95
# MODEL_MAX_ECE=0.15
# Experimental model gates (defaults): 30 / 8 / 8 / 10 / 0.9 / 0.25
# MODEL_EXP_MIN_GRADED=30
# MODEL_EXP_MIN_WINS=8
# MODEL_EXP_MIN_LOSSES=8
# MODEL_EXP_MIN_HOLDOUT=10
# MODEL_EXP_MIN_COVERAGE=0.9
# MODEL_EXP_MAX_ECE=0.25
# Retrain policy (defaults): 25 new graded / 24h between / 0.95 coverage
# LEARN_MIN_NEW_OUTCOMES=25
# LEARN_MIN_HOURS_BETWEEN=24
# LEARN_MIN_COVERAGE=0.95

# --------------------------------------------------------------------------
# Extended-hours + tuning knobs — optional (all have production-safe defaults)
# --------------------------------------------------------------------------
# PAPER_STOCK_EXTENDED_HOURS, PAPER_STOCK_SESSIONS, extended_stock_notify, and the
# large SCANNER_*, PAPER_*, GOLD_*, SWING_*, *_CALL_*, MAJOR_MOVE_*, DRIFT_*,
# EVIDENCE_*, OPP_* families are optional tuning overrides. Leave unset unless you
# are deliberately re-tuning; the in-code defaults are the production baseline.

# ==========================================================================
# STAGE PROFILES (see docs/RAILWAY_DEPLOYMENT.md)
# ==========================================================================
# STAGE A — infrastructure validation (safe):
#   NODE_ENV=production, ALERT_DB_DIR=/app/data, POLYGON_API_KEY=...,
#   SCAN_API_TOKEN=..., (webhooks optional)
#   SUPERVISOR_RUNTIME=0, CALLOUT_CANONICAL_PATH=legacy, AGENT_CALLOUT_DISCORD=0,
#   IMPROVEMENT_AUDIT=0
#
# STAGE B — supervisor dry observation (no new Discord sends):
#   ...as Stage A, but:
#   SUPERVISOR_RUNTIME=1
#   CALLOUT_CANONICAL_PATH=legacy      (keep legacy canonical → supervisor does NOT send)
#   AGENT_CALLOUT_DISCORD=0
#   Observe canonical callouts via /api/callouts and /api/runtime/status.
#
# STAGE C — live Discord paper/research callouts:
#   ...as Stage B, but:
#   CALLOUT_CANONICAL_PATH=supervisor  (supervisor becomes the ONE options sender)
#   AGENT_CALLOUT_DISCORD=1
#   DISCORD_WEBHOOK_OPTIONS=... (and DISCORD_WEBHOOK_STOCKS for stock callouts)
#   Puts stay RESEARCH_ONLY; no live brokerage; improvement automation stays OFF.
